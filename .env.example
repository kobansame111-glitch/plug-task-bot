# ======================================
# Discord Bot の設定
# ======================================
# Discord Developer Portal で取得したボットトークン
DISCORD_BOT_TOKEN=ここにDiscordボットトークンを貼り付け

# タスク通知を送るチャンネルのID（右クリック→IDをコピー）
DISCORD_TASK_CHANNEL_ID=123456789012345678

# GitHub通知を送るチャンネルのID
DISCORD_GITHUB_CHANNEL_ID=123456789012345678

# ======================================
# Google Calendar の設定
# ======================================
# Google Cloud Console で作成した credentials.json のパス
GOOGLE_CREDENTIALS_FILE=credentials.json

# カレンダーID（通常はメールアドレス）
GOOGLE_CALENDAR_ID=your-email@gmail.com

# ======================================
# GitHub の設定
# ======================================
# GitHub Personal Access Token（Settings → Developer settings → Personal access tokens）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 監視するリポジトリ（カンマ区切りで複数指定可能）
# 例: owner/repo1,owner/repo2
GITHUB_REPOS=your-username/your-repo

# 監視間隔（分単位、デフォルト5分）
GITHUB_CHECK_INTERVAL=5
